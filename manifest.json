{
  "manifest_version": 3,
  "name": "SnippetFocus",
  "version": "1.0.0",
  "description": "Gerenciamento de snippets, leitor em modo foco e integração com APIs externas para desenvolvedores.",
  "author": "SnippetFocus Team",
  "homepage_url": "https://github.com/your-username/snippet-focus-extension",

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "SnippetFocus"
  },

  "options_page": "options.html",

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "contextMenus",
    "notifications",
    "clipboardRead",
    "clipboardWrite",
    "debugger"
  ],

  "host_permissions": [
    "https://api.github.com/*",
    "https://pastebin.com/*",
    "https://api.openai.com/*"
  ],

  "web_accessible_resources": [
    {
      "resources": ["popup.html", "options.html", "focus-reader.html", "icons/*", "popup.css", "options.css"],
      "matches": ["<all_urls>"]
    }
  ],

  "commands": {
    "toggle-focus-mode": {
      "suggested_key": {
        "default": "Alt+F",
        "mac": "Alt+F"
      },
      "description": "Ativar/desativar modo foco"
    },
    "save-snippet": {
      "suggested_key": {
        "default": "Alt+S",
        "mac": "Alt+S"
      },
      "description": "Salvar seleção como snippet"
    }
  },

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
